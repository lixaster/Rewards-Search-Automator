{
  "name": "Rewards 自动搜索器",
  "version": "2.2.0.1",
  "description": "(中文)通过这个扩展程序，您可以自动化在必应搜索引擎上的搜索，以赚取微软奖励的积分。",
  "manifest_version": 3,
  "author": "Andrea Corriga - Strifelab/ modified by lixaster",
  "action": {
    "default_popup": "index.html",
    "default_title": "自动搜索器"
  },
  "permissions": ["debugger", "tabs", "alarms", "storage"],
  "icons": {
    "16": "img/icon16.png",
    "48": "img/icon48.png",
    "128": "img/icon128.png"
  },
  "background": {
    "service_worker": "./js/background.js",
    "type": "module"
  }
}
